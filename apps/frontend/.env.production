# ANADOLU REALM - Production Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL=https://api.anadolurealm.com
NEXT_PUBLIC_WS_URL=wss://api.anadolurealm.com

# App Configuration
NEXT_PUBLIC_APP_NAME=ANADOLU REALM
NEXT_PUBLIC_APP_URL=https://anadolurealm.com

# Analytics (optional - add your keys)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_ANALYTICS_ID=

# Feature Flags
NEXT_PUBLIC_ENABLE_3D_MODE=true
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_MARKETPLACE=false

# Build Configuration
NODE_ENV=production
ANALYZE=false
