{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "jsx": "preserve",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "composite": true,
    "incremental": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@tdm/shared/*": ["./packages/shared/src/*"],
      "@tdm/database/*": ["./packages/database/src/*"],
      "@tdm/pixel-engine/*": ["./packages/pixel-engine/src/*"],
      "@tdm/ui-kit/*": ["./packages/ui-kit/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "coverage"]
}
